modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[[workflows.workflow]]
name = "Run App"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/bridgix && pnpm run dev"
waitForPort = 20154

[workflows.workflow.tasks.env]
PORT = "20154"
BASE_PATH = "/"

[[workflows.workflow]]
name = "artifacts/mockup-sandbox: Component Preview Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "XegfDyZt7HqfW2Bb8Ghoy"
isCanvasWorkflow = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/mockup-sandbox run dev"
cwd = "./artifacts/mockup-sandbox"
waitForPort = 8081
ensurePreviewReachable = "/"
router = "path"

[workflows.workflow.tasks.env]
PORT = "8081"
BASE_PATH = "/__mockup"

[[workflows.workflow]]
name = "artifacts/bridgix: web"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "artifacts/bridgix"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/bridgix run dev"
cwd = "./artifacts/bridgix"
waitForPort = 20154
ensurePreviewReachable = "/"
router = "path"

[workflows.workflow.tasks.env]
PORT = "20154"
BASE_PATH = "/"

[[workflows.workflow]]
name = "artifacts/api-server: API Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "3B4_FFSkEVBkAeYMFRJ2e"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run dev"
cwd = "./artifacts/api-server"
waitForPort = 8080
ensurePreviewReachable = "/api/health"
router = "path"

[workflows.workflow.tasks.env]
PORT = "8080"
DATABASE_URL = "postgresql://postgres:bridigix@127.0.0.1:5432/bridigix"
OPENROUTER_API_KEY = "${OPENROUTER_API_KEY}"
SUPABASE_URL = "https://vtgbivniyrrmtyyczvjn.supabase.co"
SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZ0Z2Jpdm5peXJybXR5eWN6dmpuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE4NjE2OTQsImV4cCI6MjA5NzQzNzY5NH0.pyrT_F3Wf01DGmauxhP2hbSpS7LHpKxUq3LqQOFVbi8"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 20154
externalPort = 80

[userenv]

[userenv.shared]
SUPABASE_URL = "https://vtgbivniyrrmtyyczvjn.supabase.co"
SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZ0Z2Jpdm5peXJybXR5eWN6dmpuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE4NjE2OTQsImV4cCI6MjA5NzQzNzY5NH0.pyrT_F3Wf01DGmauxhP2hbSpS7LHpKxUq3LqQOFVbi8"
