# Frontend build/runtime
BASE_PATH=/
API_TARGET=http://127.0.0.1:8080

# Backend runtime
NODE_ENV=development
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info

# CORS: comma-separated list of allowed origins. Leave empty to allow localhost only in dev.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Database (required at runtime)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/postgres

# Supabase integration (optional, but required when admin routes or storage features are enabled)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Authentication / Security (backend only)
ADMIN_PASSWORD=bridigix2025admin

# AI provider (required when chat routes are enabled)
OPENROUTER_API_KEY=your-openrouter-api-key
